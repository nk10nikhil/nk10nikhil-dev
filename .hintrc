{
  "extends": ["development"],
  "hints": {
    "axe/name-role-value": [
      "default",
      {
        "link-name": "off",
        "button-name": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "backdrop-filter",
          "image-rendering: crisp-edges"
        ]
      }
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": ["iframe[loading]", "meta[name=theme-color]"]
      }
    ],
    "axe/keyboard": [
      "default",
      {
        "nested-interactive": "off"
      }
    ],
    "no-inline-styles": "off",
    "axe/aria": "off"
  }
}
